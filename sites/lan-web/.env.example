# WSDoD LAN 2026 web service — environment config.
# Copy to .env for local dev, or deploy as /etc/ktp/lan-web.env (see deploy/lan-web.service).

# --- App ---
LAN_WEB_ENV=dev                       # dev | prod  (prod sets Secure cookies)
LAN_WEB_SECRET_KEY=                   # session signing key; generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
LAN_WEB_BASE_URL=http://127.0.0.1:8099
LAN_WEB_BIND_HOST=127.0.0.1
LAN_WEB_BIND_PORT=8099
LAN_WEB_ROOT_PATH=                    # leave empty in dev; set to /lan when served behind nginx at /lan/

# --- Discord OAuth ---
# Create an app at https://discord.com/developers/applications
#   OAuth2 → add redirect: https://YOUR_DOMAIN/lan/auth/callback  (dev: http://127.0.0.1:8099/auth/callback)
#   Scopes used: identify
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=                 # full public URL of the callback; must match the Discord app exactly

# Comma/space-separated Discord IDs allowed to run staff controls (open/close/compute poll, etc.)
LAN_ADMIN_DISCORD_IDS=

# --- Database (dedicated LAN DB on the existing MySQL server) ---
# One-time setup as MySQL root:
#   CREATE DATABASE ktp_lan CHARACTER SET utf8mb4;
#   CREATE USER 'ktp_lan'@'localhost' IDENTIFIED BY '<pick-a-password>';
#   GRANT ALL PRIVILEGES ON ktp_lan.* TO 'ktp_lan'@'localhost';
#   FLUSH PRIVILEGES;
LAN_DB_HOST=127.0.0.1
LAN_DB_PORT=3306
LAN_DB_USER=ktp_lan
LAN_DB_PASSWORD=
LAN_DB_NAME=ktp_lan

# --- Demo archive ---
# Where uploaded (zipped) demos are stored. Keep it OUTSIDE /opt/lan-web so a
# code redeploy (cp -a) never wipes uploads. Prod: /var/lib/lan-web/demos
LAN_DEMO_DIR=
LAN_DEMO_MAX_MB=250
