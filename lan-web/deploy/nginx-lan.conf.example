# Reverse-proxy the LAN web service under /lan/.
# Drop inside the TLS server{} block for your LAN domain (Let's Encrypt).
#
# The trailing slash on proxy_pass strips the /lan prefix before the app sees
# the path; LAN_WEB_ROOT_PATH=/lan makes the app emit correct /lan/... links.
# The Discord OAuth redirect URI must be:  https://YOUR_DOMAIN/lan/auth/callback

location /lan/ {
    proxy_pass http://127.0.0.1:8099/;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Prefix /lan;
}
