; KTP Discord Integration Configuration
; Generated by KTP deployment system
; Profile: {{ 'online' if profile.discord_enabled else 'lan' }}
;
; Key names MUST match what the plugins parse (ktp_discord.inc reads
; discord_relay_url / discord_auth_secret / discord_channel_id* incl. _12man,
; _admin, and any *_audit* key; ktp_matchhandler_discord.inc additionally reads
; discord_channel_id_default). The relay URL MUST end in /reply (the plugin
; POSTs to it verbatim and derives /health by swapping /reply).
;
; VALUES MUST NOT BE QUOTED — the parsers do copy+trim only, so quotes become
; part of the value ("" is a 2-char value that defeats the empty-key skip and
; enables Discord with garbage config). Empty = nothing after the '='.

{% if profile.discord_enabled %}
; Discord Relay URL (Cloud Run service) — service is "discord-relay" in project
; ktp-score-bot. Format: https://discord-relay-<hash>-<region>.run.app/reply
discord_relay_url =

; Authentication secret (shared with relay service; openssl rand -hex 32)
discord_auth_secret =

; Primary + per-mode match channels (empty = fall back to discord_channel_id)
discord_channel_id =
discord_channel_id_default =
discord_channel_id_12man =
discord_channel_id_scrim =
discord_channel_id_draft =

; Admin channel (ktp_discord.inc consumers; also joins the audit set)
discord_channel_id_admin =

; Audit channels (KTPAdminAudit + KTPFileChecker; any *_audit* key is collected)
discord_channel_id_audit =
discord_channel_id_audit_external =
{% else %}
; Discord disabled for LAN mode — keys kept (correct names) but empty
discord_relay_url =
discord_auth_secret =
discord_channel_id =
discord_channel_id_default =
discord_channel_id_12man =
discord_channel_id_scrim =
discord_channel_id_draft =
discord_channel_id_admin =
discord_channel_id_audit =
discord_channel_id_audit_external =
{% endif %}
