# KTP LAN Deployment Config
#
# Copy this to lan-deploy.conf, fill in the required values, then run:
#   sudo ./lan-deploy.sh
#
# Required keys are marked with *. Everything else has a sensible default.
# Empty values are treated as "unset" (use defaults / disable feature).

# ============================================================================
# Required
# ============================================================================

# * Local network IP the game servers and (if co-located) the dataserver
#   bind to. Must be reachable by every client at the LAN venue.
LAN_IP=""

# * Path to the directory holding pre-built KTP artifacts (engine_i486.so,
#   hlds_linux, KTPAMXX dlls/, modules/, plugins/, etc). Same layout that
#   clone-ktp-stack.sh expects.
ARTIFACTS_PATH=""

# * Path to the KTP libsteam_api.so (76KB version — NOT the 375KB stock one).
LIBSTEAM_API_PATH=""

# Optional but strongly recommended for LAN: pre-staged HLTV binaries
# directory. The contents are copied wholesale into /home/hltvserver/hlds/.
# Produce the bundle from an existing data server with
# scripts/package-hltv-bundle.sh (excludes recorded .dem files and the
# unused cstrike/ tree, ~5-15 GB depending on which maps you keep).
# Leave empty to keep the original manual-copy workflow.
HLTV_BINARIES_PATH=""

# Optional: pre-staged HLStatsX install directory (scripts/ + sql/).
# Produce with scripts/package-hlstatsx-bundle.sh on a current data server.
# When set, the dataserver phase will copy scripts/sql into /opt/hlstatsx/,
# import the schemas, write hlstats.conf with the DB password generated
# above, and enable hlstatsx.service. Empty = leave HLStatsX unconfigured
# (an INSTALL.txt with manual steps is created instead).
HLSTATSX_SOURCE_PATH=""

# Optional: pre-staged FastDL game-files directory (maps/, sprites/, sound/,
# models/ — the dod/ asset tree). Contents are copied to /var/www/fastdl/dod/.
# Produce with scripts/package-fastdl-bundle.sh on a current data server
# (use --maps-only for a much smaller bundle if you only need new maps).
# Empty = clients can't download missing assets via HTTP.
FASTDL_FILES_PATH=""

# ============================================================================
# Host config (optional, sensible defaults)
# ============================================================================

# Set to the LAN venue's local timezone if not Eastern.
TIMEZONE="America/New_York"

# Server display name prefix (each instance gets "<prefix> N" appended).
SERVER_NAME_PREFIX="KTP LAN"

# sv_password — server join password.
SV_PASSWORD="ktplan"

# Number of DoD game server instances and starting port.
NUM_INSTANCES=5
BASE_PORT=27015

# HLTV proxy starting port (the dataserver provisioner uses this too).
HLTV_BASE_PORT=27020

# ============================================================================
# Optional services
# ============================================================================

# Co-locate the dataserver (MySQL + HLStatsX + HLTV proxies + FastDL) on the
# same host. Set false to skip this phase if dataserver lives on a separate
# box (run provision-lan-dataserver.sh there manually).
ENABLE_DATASERVER=true

# Install Netdata. Requires internet access to fetch the installer.
ENABLE_NETDATA=false

# ============================================================================
# Discord (all optional — empty URLs mean "skip Discord posts")
# ============================================================================

# Scheduled-restart relay (used by the nightly 3 AM ET ktp-scheduled-restart.sh
# embed). Leave empty if the LAN venue can't reach the relay or doesn't
# want restart notifications.
DISCORD_RELAY_URL=""
DISCORD_RELAY_SECRET=""

# Fleet-health alerter (posts when game server count drops below NUM_INSTANCES
# for THRESHOLD_MINUTES consecutive minutes). Leave empty to monitor silently.
DISCORD_WEBHOOK_FLEET_HEALTH=""
DISCORD_MENTION_USER_ID=""

# ============================================================================
# Dataserver passwords (optional — auto-generated random if empty)
# ============================================================================
# All values end up in /root/ktp-dataserver-credentials.txt after the run.
# Leave empty to get fresh random 32-char passwords per deployment.

MYSQL_ROOT_PASSWORD=""
HLSTATSX_DB_PASSWORD=""
HLTV_ADMIN_PASSWORD=""
HLTV_PROXY_PASSWORD=""
