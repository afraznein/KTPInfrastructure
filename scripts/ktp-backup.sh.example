#!/bin/bash
# KTP Backup Script
# Backs up MySQL database and key configuration files
#
# Location: /opt/ktp-backup.sh (on data server)
# Cron: 0 3 * * 0 /opt/ktp-backup.sh >> /var/log/ktp-backup.log 2>&1
#
# Configuration:
#   Copy this file to ktp-backup.sh and write the hlstatsx MySQL password to
#   /root/.ktp-backup.my.cnf (mode 0600):
#     [client]
#     user=hlstatsx
#     password=<MYSQL_PASS>
#   (--defaults-extra-file keeps the password out of `ps` / /proc/cmdline —
#   the inline -p"$PASS" form leaked it for the dump's duration.)

# pipefail is load-bearing: without it, `mysqldump | gzip` reports GZIP's
# status — a mid-dump mysqldump failure (MySQL restart, lock timeout) would
# gzip a truncated dump successfully, pass the size sanity, and reach the
# retention prune with a corrupt backup.
set -uo pipefail

BACKUP_DIR="/opt/backups"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
MYSQL_CNF="/root/.ktp-backup.my.cnf"

[ -f "$MYSQL_CNF" ] || { echo "ERROR: $MYSQL_CNF missing (see header) — aborting"; exit 1; }

mkdir -p "$BACKUP_DIR"

# Dump first, gate EVERYTHING else on its success. The old flow pruned
# unconditionally: 4 consecutive failed weekly dumps (MySQL down, rotated
# password) silently destroyed every good backup while printing
# "Backup complete". Now a failed dump keeps the old backups and exits 1.
if ! mysqldump --defaults-extra-file="$MYSQL_CNF" hlstatsx | gzip > "$BACKUP_DIR/hlstatsx_$TIMESTAMP.sql.gz"; then
    echo "ERROR: mysqldump FAILED — keeping existing backups, skipping retention prune"
    rm -f "$BACKUP_DIR/hlstatsx_$TIMESTAMP.sql.gz"
    exit 1
fi
# Guard against a zero-row "success" (empty pipe still gzips ~20 bytes).
if [ "$(stat -c '%s' "$BACKUP_DIR/hlstatsx_$TIMESTAMP.sql.gz")" -lt 1024 ]; then
    echo "ERROR: dump suspiciously small ($(stat -c '%s' "$BACKUP_DIR/hlstatsx_$TIMESTAMP.sql.gz") bytes) — keeping existing backups, skipping prune"
    rm -f "$BACKUP_DIR/hlstatsx_$TIMESTAMP.sql.gz"
    exit 1
fi

tar -czf "$BACKUP_DIR/configs_$TIMESTAMP.tar.gz" /opt/ktp-file-distributor/*.json /opt/hlstatsx/scripts/*.conf /home/dod/distribute/addons/ktpamx/configs/ /etc/systemd/system/ktp-*.service /etc/systemd/system/hlstatsx.service 2>/dev/null

# Retention prune — only reached after a verified-good dump.
find "$BACKUP_DIR" -name "*.sql" -mtime +28 -delete
find "$BACKUP_DIR" -name "*.sql.gz" -mtime +28 -delete
find "$BACKUP_DIR" -name "*.tar.gz" -mtime +28 -delete
echo "Backup complete: $TIMESTAMP ($(stat -c '%s' "$BACKUP_DIR/hlstatsx_$TIMESTAMP.sql.gz") bytes gzipped)"
