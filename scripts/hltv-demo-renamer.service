[Unit]
Description=KTP HLTV Demo Renamer — match-window-driven rename of auto-* demos
Documentation=https://github.com/afraznein/KTPInfrastructure/blob/main/scripts/README-hltv-demo-renamer.md
After=network-online.target hltv-api.service
Wants=network-online.target
# StartLimitIntervalSec + StartLimitBurst belong in [Unit] per systemd.unit(5),
# NOT [Service]. The latter placement triggers
#   "Unknown key name 'StartLimitIntervalSec' in section 'Service', ignoring"
# at unit-load time, which silently disables the restart rate-limiting.
# Fixed 2026-05-02.
StartLimitIntervalSec=300
StartLimitBurst=5
# Page on terminal failure: a dead renamer means every match demo gets swept
# as an unrenamed auto-*.dem by the 6h cleanup cron — silent league-demo loss.
# Fires when Restart= gives up (StartLimitBurst exhausted) or a non-restart
# failure lands. Requires ktp-systemd-alert@.service on the host (deployed on
# the data server since 2026-04; see scripts/ktp-systemd-alert.py).
OnFailure=ktp-systemd-alert@%n.service

[Service]
Type=simple
User=root
Group=root
ExecStart=/usr/bin/python3 /usr/local/bin/hltv-demo-renamer.py
Restart=on-failure
RestartSec=15

# State + log directories
StateDirectory=hltv-demo-renamer
RuntimeDirectory=hltv-demo-renamer

StandardOutput=journal
StandardError=journal
SyslogIdentifier=hltv-demo-renamer

[Install]
WantedBy=multi-user.target
